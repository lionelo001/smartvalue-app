<svg width="1200" height="630" xmlns="http://www.w3.org/2000/svg" font-family="'DM Sans', sans-serif">
  <defs>
    <linearGradient id="bg" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#F2F4F7"/>
      <stop offset="100%" stop-color="#E8EBF2"/>
    </linearGradient>
    <linearGradient id="card1" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#ffffff"/>
      <stop offset="100%" stop-color="#f8fafc"/>
    </linearGradient>
  </defs>

  <!-- Fond -->
  <rect width="1200" height="630" fill="url(#bg)"/>

  <!-- Grille de fond subtile -->
  <g opacity="0.25">
    <line x1="0" y1="105" x2="1200" y2="105" stroke="#CBD5E1" stroke-width="1"/>
    <line x1="0" y1="210" x2="1200" y2="210" stroke="#CBD5E1" stroke-width="1"/>
    <line x1="0" y1="315" x2="1200" y2="315" stroke="#CBD5E1" stroke-width="1"/>
    <line x1="0" y1="420" x2="1200" y2="420" stroke="#CBD5E1" stroke-width="1"/>
    <line x1="0" y1="525" x2="1200" y2="525" stroke="#CBD5E1" stroke-width="1"/>
    <line x1="200" y1="0" x2="200" y2="630" stroke="#CBD5E1" stroke-width="1"/>
    <line x1="400" y1="0" x2="400" y2="630" stroke="#CBD5E1" stroke-width="1"/>
    <line x1="600" y1="0" x2="600" y2="630" stroke="#CBD5E1" stroke-width="1"/>
    <line x1="800" y1="0" x2="800" y2="630" stroke="#CBD5E1" stroke-width="1"/>
    <line x1="1000" y1="0" x2="1000" y2="630" stroke="#CBD5E1" stroke-width="1"/>
  </g>

  <!-- Partie gauche — texte -->
  <text x="80" y="200" font-family="'Syne', sans-serif" font-size="64" font-weight="800" fill="#1E2330" letter-spacing="-2">Smart<tspan fill="#2563EB">Value</tspan></text>
  <text x="80" y="255" font-family="'DM Sans', sans-serif" font-size="26" font-weight="400" fill="#6B7080">Scanner d'actions</text>

  <!-- Ligne séparatrice -->
  <rect x="80" y="285" width="60" height="3" fill="#2563EB" rx="2"/>

  <text x="80" y="340" font-family="'DM Sans', sans-serif" font-size="20" font-weight="300" fill="#6B7080">Analysez les entreprises mondiales</text>
  <text x="80" y="368" font-family="'DM Sans', sans-serif" font-size="20" font-weight="300" fill="#6B7080">selon des critères fondamentaux clairs.</text>

  <!-- Tags -->
  <rect x="80" y="400" width="120" height="32" rx="5" fill="#EFF6FF" stroke="#BFDBFE" stroke-width="1.5"/>
  <text x="140" y="421" font-family="'DM Mono', monospace" font-size="13" fill="#2563EB" text-anchor="middle">Gratuit</text>

  <rect x="212" y="400" width="120" height="32" rx="5" fill="#EFF6FF" stroke="#BFDBFE" stroke-width="1.5"/>
  <text x="272" y="421" font-family="'DM Mono', monospace" font-size="13" fill="#2563EB" text-anchor="middle">En français</text>

  <rect x="344" y="400" width="160" height="32" rx="5" fill="#EFF6FF" stroke="#BFDBFE" stroke-width="1.5"/>
  <text x="424" y="421" font-family="'DM Mono', monospace" font-size="13" fill="#2563EB" text-anchor="middle">US · Europe · Asie</text>

  <!-- URL -->
  <text x="80" y="545" font-family="'DM Mono', monospace" font-size="16" fill="#9096A8">smartvaluescanner.com</text>

  <!-- Badge Live -->
  <rect x="80" y="560" width="80" height="24" rx="12" fill="#DCFCE7"/>
  <circle cx="97" cy="572" r="4" fill="#16A34A"/>
  <text x="106" y="577" font-family="'DM Mono', monospace" font-size="12" fill="#16A34A">Live</text>

  <!-- Partie droite — aperçu de l'app -->
  <rect x="620" y="40" width="540" height="550" rx="12" fill="white" filter="url(#shadow)"/>
  <defs>
    <filter id="shadow" x="-5%" y="-5%" width="110%" height="110%">
      <feDropShadow dx="0" dy="4" stdDeviation="16" flood-color="#1E2330" flood-opacity="0.10"/>
    </filter>
  </defs>

  <!-- Barre du navigateur -->
  <rect x="620" y="40" width="540" height="44" rx="12" fill="#E8EBF2"/>
  <rect x="620" y="72" width="540" height="12" fill="#E8EBF2"/>
  <circle cx="648" cy="62" r="6" fill="#FF5F57"/>
  <circle cx="668" cy="62" r="6" fill="#FEBC2E"/>
  <circle cx="688" cy="62" r="6" fill="#28C840"/>
  <rect x="730" y="52" width="220" height="20" rx="5" fill="white"/>
  <text x="840" y="67" font-family="'DM Mono', monospace" font-size="10" fill="#9096A8" text-anchor="middle">smartvaluescanner.com/app</text>

  <!-- Contenu app -->
  <!-- Profils -->
  <rect x="636" y="100" width="156" height="62" rx="6" fill="#F8FAFC" stroke="#E2E8F0" stroke-width="1"/>
  <text x="714" y="125" font-family="'Syne', sans-serif" font-size="12" font-weight="700" fill="#6B7080" text-anchor="middle">🛡 Défensif</text>
  <text x="714" y="145" font-family="'DM Sans', sans-serif" font-size="10" fill="#9096A8" text-anchor="middle">Stable, dividendes</text>

  <rect x="800" y="100" width="156" height="62" rx="6" fill="#1E2330"/>
  <text x="878" y="125" font-family="'Syne', sans-serif" font-size="12" font-weight="700" fill="white" text-anchor="middle">⚖ Universel</text>
  <text x="878" y="145" font-family="'DM Sans', sans-serif" font-size="10" fill="#9096A8" text-anchor="middle">Tous secteurs</text>

  <rect x="964" y="100" width="156" height="62" rx="6" fill="#F8FAFC" stroke="#E2E8F0" stroke-width="1"/>
  <text x="1042" y="125" font-family="'Syne', sans-serif" font-size="12" font-weight="700" fill="#6B7080" text-anchor="middle">🚀 Croissance</text>
  <text x="1042" y="145" font-family="'DM Sans', sans-serif" font-size="10" fill="#9096A8" text-anchor="middle">Tech, innovation</text>

  <!-- Carte 1 — TSM -->
  <rect x="636" y="182" width="484" height="80" rx="8" fill="white" stroke="#E2E8F0" stroke-width="1"/>
  <rect x="650" y="202" width="36" height="36" rx="8" fill="#7C3AED"/>
  <text x="668" y="225" font-family="'Syne', sans-serif" font-size="11" font-weight="800" fill="white" text-anchor="middle">TS</text>
  <text x="702" y="210" font-family="'Syne', sans-serif" font-size="14" font-weight="800" fill="#1E2330">TSM</text>
  <text x="702" y="226" font-family="'DM Sans', sans-serif" font-size="11" fill="#6B7080">Taiwan Semiconductor</text>
  <rect x="702" y="232" width="52" height="16" rx="3" fill="#F1F5F9" stroke="#E2E8F0" stroke-width="1"/>
  <text x="728" y="244" font-family="'DM Mono', monospace" font-size="9" fill="#6B7080" text-anchor="middle">QUALITÉ</text>
  <text x="1062" y="217" font-family="'DM Mono', monospace" font-size="22" font-weight="500" fill="#16A34A" text-anchor="end">74.8</text>
  <rect x="1032" y="228" width="36" height="16" rx="8" fill="#DCFCE7"/>
  <text x="1050" y="240" font-family="'DM Mono', monospace" font-size="10" fill="#16A34A" text-anchor="middle">88%</text>

  <!-- Carte 2 — META -->
  <rect x="636" y="272" width="484" height="80" rx="8" fill="white" stroke="#E2E8F0" stroke-width="1"/>
  <rect x="650" y="292" width="36" height="36" rx="8" fill="#EA580C"/>
  <text x="668" y="315" font-family="'Syne', sans-serif" font-size="11" font-weight="800" fill="white" text-anchor="middle">ME</text>
  <text x="702" y="300" font-family="'Syne', sans-serif" font-size="14" font-weight="800" fill="#1E2330">META</text>
  <text x="702" y="316" font-family="'DM Sans', sans-serif" font-size="11" fill="#6B7080">Meta Platforms</text>
  <rect x="702" y="322" width="52" height="16" rx="3" fill="#F1F5F9" stroke="#E2E8F0" stroke-width="1"/>
  <text x="728" y="334" font-family="'DM Mono', monospace" font-size="9" fill="#6B7080" text-anchor="middle">QUALITÉ</text>
  <text x="1062" y="307" font-family="'DM Mono', monospace" font-size="22" font-weight="500" fill="#16A34A" text-anchor="end">69.6</text>
  <rect x="1032" y="318" width="36" height="16" rx="8" fill="#DCFCE7"/>
  <text x="1050" y="330" font-family="'DM Mono', monospace" font-size="10" fill="#16A34A" text-anchor="middle">92%</text>

  <!-- Carte 3 — ADBE -->
  <rect x="636" y="362" width="484" height="80" rx="8" fill="white" stroke="#E2E8F0" stroke-width="1"/>
  <rect x="650" y="382" width="36" height="36" rx="8" fill="#2563EB"/>
  <text x="668" y="405" font-family="'Syne', sans-serif" font-size="11" font-weight="800" fill="white" text-anchor="middle">AD</text>
  <text x="702" y="390" font-family="'Syne', sans-serif" font-size="14" font-weight="800" fill="#1E2330">ADBE</text>
  <text x="702" y="406" font-family="'DM Sans', sans-serif" font-size="11" fill="#6B7080">Adobe Inc.</text>
  <rect x="702" y="412" width="40" height="16" rx="3" fill="#F1F5F9" stroke="#E2E8F0" stroke-width="1"/>
  <text x="722" y="424" font-family="'DM Mono', monospace" font-size="9" fill="#6B7080" text-anchor="middle">VALUE</text>
  <text x="1062" y="397" font-family="'DM Mono', monospace" font-size="22" font-weight="500" fill="#EA580C" text-anchor="end">69.0</text>
  <rect x="1032" y="408" width="36" height="16" rx="8" fill="#DCFCE7"/>
  <text x="1050" y="420" font-family="'DM Mono', monospace" font-size="10" fill="#16A34A" text-anchor="middle">92%</text>

  <!-- Stats en bas -->
  <rect x="636" y="460" width="484" height="110" rx="8" fill="#F8FAFC" stroke="#E2E8F0" stroke-width="1"/>
  <line x1="757" y1="470" x2="757" y2="560" stroke="#E2E8F0" stroke-width="1"/>
  <line x1="878" y1="470" x2="878" y2="560" stroke="#E2E8F0" stroke-width="1"/>
  <line x1="999" y1="470" x2="999" y2="560" stroke="#E2E8F0" stroke-width="1"/>

  <text x="696" y="500" font-family="'DM Mono', monospace" font-size="22" font-weight="500" fill="#2563EB" text-anchor="middle">100+</text>
  <text x="696" y="520" font-family="'DM Sans', sans-serif" font-size="10" fill="#9096A8" text-anchor="middle">Actions</text>

  <text x="817" y="500" font-family="'DM Mono', monospace" font-size="22" font-weight="500" fill="#2563EB" text-anchor="middle">15+</text>
  <text x="817" y="520" font-family="'DM Sans', sans-serif" font-size="10" fill="#9096A8" text-anchor="middle">Marchés</text>

  <text x="938" y="500" font-family="'DM Mono', monospace" font-size="22" font-weight="500" fill="#2563EB" text-anchor="middle">5</text>
  <text x="938" y="520" font-family="'DM Sans', sans-serif" font-size="10" fill="#9096A8" text-anchor="middle">Blocs scoring</text>

  <text x="1059" y="500" font-family="'DM Mono', monospace" font-size="22" font-weight="500" fill="#2563EB" text-anchor="middle">0€</text>
  <text x="1059" y="520" font-family="'DM Sans', sans-serif" font-size="10" fill="#9096A8" text-anchor="middle">Pour commencer</text>

</svg>
